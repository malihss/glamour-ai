{
  "name": "glamour-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"api,web\" -c \"cyan.bold,magenta.bold\" --kill-others-on-fail \"npm run api\" \"npm run web\"",
    "api": "cd backend && ./venv/bin/python app.py",
    "web": "cd frontend && npm run dev",
    "install:deps": "cd frontend && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
